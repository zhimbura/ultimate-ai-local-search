# ─── ultimate-ai-local-search config ────────────────────────────────────────
# Copy to .env (install.sh does this for you). .env is gitignored — never commit keys.

# ─── Milvus (vector DB, runs locally in Docker) ──────────────────────────────
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_VERSION=v2.5.6
ETCD_VERSION=v3.5.18
MINIO_VERSION=RELEASE.2023-03-20T20-16-18Z
# Use 127.0.0.1, NOT localhost — on some machines localhost resolves to IPv6 ::1
# and proxies/resolvers make it flaky. Raw IPv4 is deterministic.
MILVUS_ADDRESS=127.0.0.1:19530

# ─── Tier 1: ast-index (structural symbol search) ────────────────────────────
# On Linux the installer downloads this prebuilt version; macOS uses Homebrew.
AST_INDEX_VERSION=3.48.0

# ─── Embedding provider ──────────────────────────────────────────────────────
# One of: Ollama | OpenAI | VoyageAI | Gemini | OpenRouter
# (LM Studio is selected as OpenAI with a custom OPENAI_BASE_URL — see below.)
EMBEDDING_PROVIDER=Ollama

# Model name AND dimension MUST match — a wrong dimension makes every insert
# silently fail (Milvus rejects the batch). install.sh sets a correct pair for you.
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# ─── Local provider: Ollama (default, headless) ──────────────────────────────
# nomic-embed-text=768 · mxbai-embed-large=1024 · bge-m3=1024
OLLAMA_HOST=http://127.0.0.1:11434

# ─── Local provider: LM Studio (OpenAI-compatible REST) ──────────────────────
# Set EMBEDDING_PROVIDER=OpenAI and point the base URL at LM Studio:
#   OPENAI_BASE_URL=http://127.0.0.1:1234/v1
#   OPENAI_API_KEY=lm-studio              (any non-empty string; LM Studio ignores it)
#   EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5   (dim 768)

# ─── Cloud providers (need a real API key) ───────────────────────────────────
# OpenAI:    EMBEDDING_PROVIDER=OpenAI    OPENAI_API_KEY=sk-...
#            text-embedding-3-small=1536 · text-embedding-3-large=3072
# VoyageAI:  EMBEDDING_PROVIDER=VoyageAI  VOYAGEAI_API_KEY=...   voyage-code-3=1024 (best for code)
# Gemini:    EMBEDDING_PROVIDER=Gemini    GEMINI_API_KEY=...     text-embedding-004=768
# OpenRouter:EMBEDDING_PROVIDER=OpenRouter OPENROUTER_API_KEY=...
OPENAI_API_KEY=
OPENAI_BASE_URL=
VOYAGEAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
